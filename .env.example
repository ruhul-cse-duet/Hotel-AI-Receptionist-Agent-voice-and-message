# ════════════════════════════════════════════════════════════════
# Hotel AI Receptionist — Environment Configuration
# Copy this to .env and fill in your actual values
# ════════════════════════════════════════════════════════════════

# ─── Application Core ───────────────────────────────────────────
DEBUG=true
APP_ENV=development
HOTEL_NAME=Grand Palace Hotel
HOTEL_ADDRESS=123 Main St, Dhaka, Bangladesh
HOTEL_PHONE=+880123456789
HOTEL_CHECKIN_TIME=14:00
HOTEL_CHECKOUT_TIME=11:00
HOTEL_CURRENCY=BDT

# ─── Database (MongoDB) ─────────────────────────────────────────
# Cloud: MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=hotel_ai

# Alternative: Local MongoDB
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB_NAME=hotel_ai

# ─── LLM Provider ───────────────────────────────────────────────
# Options: openai | gemini | lm_studio
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# Gemini Configuration
GEMINI_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-pro

# LM Studio (Local) Configuration
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=not-needed
LM_STUDIO_MODEL=local-model

# ─── Speech-to-Text (STT) ───────────────────────────────────────
# Options: openai_whisper | deepgram | google
STT_PROVIDER=openai_whisper

# Deepgram STT
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Cloud STT
GOOGLE_CLOUD_CREDENTIALS=/path/to/credentials.json

# ─── Text-to-Speech (TTS) ───────────────────────────────────────
# Options: openai | elevenlabs | google
TTS_PROVIDER=openai

# ElevenLabs TTS (high quality voice)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel voice

# Google Cloud TTS
GOOGLE_TTS_LANGUAGE=en-US

# ─── Twilio ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1555555555
TWILIO_WHATSAPP_NUMBER=+1555555556

# Twilio Webhook Security
VERIFY_TWILIO_SIGNATURE=false  # Set to true in production

# ─── Webhooks & Networking ──────────────────────────────────────
# For local development with ngrok
WEBHOOK_BASE_URL=https://your-ngrok-url.io
WEBHOOK_TIMEOUT_SECONDS=30

# ─── Admin & Security ───────────────────────────────────────────
ADMIN_SECRET_KEY=your-super-secret-admin-key-change-this
API_KEY_REQUIRED=false  # Set true to require API key for admin routes

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FILE=hotel_ai.log
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=5

# ─── Feature Flags ──────────────────────────────────────────────
ENABLE_VOICE_CALLS=true
ENABLE_WHATSAPP=true
ENABLE_BOOKING_CONFIRMATION_SMS=false
ENABLE_CALL_RECORDING=false
